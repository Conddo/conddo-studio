# Conddo Studio frontend environment
# Copy to .env.local for local dev.

# Base URL of the Conddo Studio backend — a SEPARATE Spring service from the
# main platform API (conddo-api). The frontend appends /api/jobs to this root.
#
# Local dev:    http://localhost:8083   (run conddo-studio with mvnw spring-boot:run)
# Production:   https://<your-studio-service>.onrender.com
#
# Do NOT point this at the main platform backend — different schemas, different auth.
NEXT_PUBLIC_STUDIO_API_URL=http://localhost:8083
